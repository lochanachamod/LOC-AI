{
  "name": "loc-ai",
  "version": "2.0.0",
  "description": "The Dual-Engine AI Coding Assistant (Offline Ollama + Online Groq) with Vision and PDF extraction.",
  "repository": {
    "type": "git",
    "url": "https://github.com/lochanachamod/LOC-AI.git"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "keywords": [
    "ai",
    "coding",
    "electron",
    "groq",
    "ollama"
  ],
  "author": "Lochana Chamod <lochanachamod7@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "highlight.js": "^11.10.0",
    "marked": "^15.0.3",
    "pdf-parse": "^2.4.5",
    "tesseract.js": "^7.0.0"
  },
  "build": {
    "appId": "com.lochana.locai",
    "productName": "LOC-AI",
    "win": {
      "target": "nsis",
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "files": [
      "**/*",
      "!dist/*",
      "!node_modules/.cache/*"
    ]
  }
}
